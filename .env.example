# FastAPI
APP_HOST=127.0.0.1
APP_PORT=8000

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Alternativa caso prefira usar uma única chave genérica no código:
# SUPABASE_KEY=your-supabase-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Segurança e operação
WEBHOOK_TOKEN=change-this-to-a-strong-random-token
LOG_LEVEL=INFO
TZ_OFFSET_HOURS=-3
TWILIO_REPLY_MODE=normal
TWILIO_SILENT_PREFIX=debug:

# Fluxo guiado: tempo (em minutos) para pedir confirmação de retomada
# Recomendado: 5 (equilíbrio entre praticidade e segurança)
GUIDED_SESSION_IDLE_MINUTES=5

# AI health confidence score (executive 0-100)
AI_CONF_PROFILE=balanced
AI_CONF_SAMPLES_TARGET=300
AI_CONF_RISK_WEIGHT=0.7
AI_CONF_FAILSAFE_WEIGHT=1.3
AI_CONF_WEIGHT_MATURITY=45
AI_CONF_WEIGHT_STABILITY=45
AI_CONF_WEIGHT_ALERTS=10
AI_CONF_BAND_EXCELLENT=85
AI_CONF_BAND_GOOD=70
AI_CONF_BAND_MODERATE=50

# Perfis disponiveis:
# - conservative: mais rigor para classificar como bom/excellent
# - balanced: equilibrio entre estabilidade e maturidade
# - aggressive: favorece evolucao rapida da maturidade
# - auto: roteia por maturidade (seed->aggressive, learning/stable->balanced, advanced->conservative)
